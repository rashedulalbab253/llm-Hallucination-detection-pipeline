# OpenAI API Key (required for GPT model evaluation)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Anthropic API Key (for Claude model evaluation)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: Google AI API Key (for Gemini model evaluation)  
GOOGLE_API_KEY=your-google-api-key-here

# Evaluation Settings
EVAL_BATCH_SIZE=10
EVAL_MAX_RETRIES=3
EVAL_RETRY_DELAY=2.0
